    "@version": 1.1,

    "id": "@id",
    "type": "@type",

    "AgentCapabilityCredential": "https://agentvc.org/vocab#AgentCapabilityCredential",

    "agentProfile": {
      "@id": "https://agentvc.org/vocab#agentProfile",
      "@context": {
        "name": "https://schema.org/name",
        "version": "https://schema.org/version",
        "model": "https://agentvc.org/vocab#model"
      }
    },

    "capabilities": {
      "@id": "https://agentvc.org/vocab#capabilities",
      "@container": "@set"
    },

    "actions": {
      "@id": "https://agentvc.org/vocab#actions",
      "@container": "@set"
    },

    "constraints": {
      "@id": "https://agentvc.org/vocab#constraints"
    },

    "allowedDomains": {
      "@id": "https://agentvc.org/vocab#allowedDomains",
