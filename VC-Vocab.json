    },

    "rateLimit": {
      "@id": "https://agentvc.org/vocab#rateLimit"
    },

    "maxExecutionTimeMs": {
      "@id": "https://agentvc.org/vocab#maxExecutionTimeMs"
    },

    "sandboxPolicy": {
      "@id": "https://agentvc.org/vocab#sandboxPolicy"
    },

    "delegationPolicy": {
      "@id": "https://agentvc.org/vocab#delegationPolicy"
    },

